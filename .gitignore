# ===================================================
# 1. DEPENDENCIAS DE NODE.JS Y ARTEFACTOS DE BUILD
# (CRITICO: Evita subir codigo de librerias y temporales)
# ===================================================
/node_modules
/dist
/tmp
/coverage

# Archivos de build generados por Webpack/Terser/CSS-Minimizer
/public/optimized/
/public/styles/*.min.css
/public/scripts/*.min.js

# Build outputs and Playwright artifacts
public_html/dist/
playwright-report/
test-results/

*.log
npm-debug.log
logs/
.npm/
.yarn/

# ===================================================
# 2. SEGURIDAD Y PRIVACIDAD (TOLERANCIA CERO)
# (CRITICO: Nunca subir secretos o claves a Git)
# ===================================================
.env
.vault
*.pem
*.key

# ===================================================
# 3. DATOS Y LOGISTICA (Grandes, Cambian Constantemente)
# ===================================================
/data/backups/
/data/logs/
/data/reports/
/data/manifests/
.hash-integrity-db.json

# ===================================================
# 4. SISTEMAS OPERATIVOS Y EDITORES (Ruido)
# ===================================================
.DS_Store
Thumbs.db

# Screenshots (no binary assets in repo)
screenshots/

# Python scripts (not part of this Node.js project)
*.py

# Prompt files (ephemeral, not source code)
PROMPT_*.md

# Visual Studio Code
.vscode/

# IDEs JetBrains
.idea/
