# ===================================================
# 1. DEPENENCIAS DE NODE.JS Y ARTEFACTOS DE BUILD
# (CRÍTICO: Evita subir código de librerías y temporales)
# ===================================================
/node_modules
/dist
/tmp
/coverage

# Archivos de build generados por Webpack/Terser/CSS-Minimizer
/public/optimized/      # CRÍTICO: Assets finales (se generan a partir de /tools/optimizer)
/public/styles/*.min.css
/public/scripts/*.min.js
*.log
npm-debug.log
logs/
.npm/
.yarn/

# ===================================================
# 2. SEGURIDAD Y PRIVACIDAD (TOLERANCIA CERO)
# (CRÍTICO: Nunca subir secretos o claves a Git)
# ===================================================
.env                    # Contiene claves API y la clave privada para FIRMAR MANIFIESTO (Fase 1.3)
.vault                  # Almacenamiento de secretos
*.pem                   # Claves de firma o certificados
*.key                   # Claves privadas

# ===================================================
# 3. DATOS Y LOGÍSTICA (Grandes, Cambian Constantemente)
# ===================================================
/data/backups/          # Backups generados por backup-manager.js
/data/logs/
/data/reports/          # Reportes de Lighthouse, pruebas, etc.
/data/manifests/        # El manifiesto final (se reconstruye)
.hash-integrity-db.json # Base de datos del QuantumHashMonitor

# ===================================================
# 4. SISTEMAS OPERATIVOS Y EDITORES (Ruido)
# ===================================================
.DS_Store               # MacOS
Thumbs.db               # Windows
# Visual Studio Code
.vscode/
# IDEs jetbrains
.idea/