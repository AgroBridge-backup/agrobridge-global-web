#!/bin/bash
#
# Post-Checkout Hook - Environment Sync
# Location: .githooks/post-checkout
#
# Runs after git checkout to ensure environment is synchronized.
# Handles: dependency updates, config validation, skill audits
#
# Exit codes:
#   0 - Always succeeds (informational only)
#

set -euo pipefail

# Colors
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
NC='\033[0m'

# Get checkout info
PREV_HEAD=$1
NEW_HEAD=$2
BRANCH_SWITCH=$3  # 1 if branch switch, 0 if file checkout

# Only run on branch switches
if [ "$BRANCH_SWITCH" -eq 0 ]; then
  exit 0
fi

NEW_BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo -e "${BLUE}🔄 Branch switched to: ${GREEN}$NEW_BRANCH${NC}"

# Check if package.json changed
if git diff --name-only $PREV_HEAD $NEW_HEAD | grep -q "package.json"; then
  echo -e "${YELLOW}⚠️  package.json changed${NC}"
  echo -e "${BLUE}   Run: npm install${NC}"
fi

# Check if .env.example changed
if git diff --name-only $PREV_HEAD $NEW_HEAD | grep -q ".env.example"; then
  echo -e "${YELLOW}⚠️  .env.example changed${NC}"
  echo -e "${BLUE}   Review: diff .env.example .env${NC}"
fi

# Check if skills changed
if git diff --name-only $PREV_HEAD $NEW_HEAD | grep -qE "\.codex/skills|/skills/"; then
  echo -e "${YELLOW}⚠️  Skills changed${NC}"
  echo -e "${BLUE}   Consider auditing: python scripts/audit_skill.py <skill>${NC}"
fi

exit 0
