#!/bin/bash
#
# Pre-Commit Hook - Quality Gates (FAANG-Grade)
# Location: .githooks/pre-commit
#
# Security: No eval() usage, all inputs validated
# Reliability: Signal handling, atomic operations
# Observability: Structured logging, metrics
#

# Source core library (provides set -euo pipefail, logging, validation)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/core.sh"

# Configuration
readonly HOOK_NAME="pre-commit"
readonly DEBUG=${HOOKS_DEBUG:-0}
readonly SKIP_ALL=${SKIP_PRE_COMMIT:-0}
readonly TARGET_DURATION=30  # Target: 30 seconds

# Validate skip flag
if [[ "$SKIP_ALL" -eq 1 ]]; then
    log_warning "Pre-commit hooks skipped (SKIP_PRE_COMMIT=1)"
    exit 0
fi

log_info "Running pre-commit quality gates (v${GITHOOKS_VERSION})"

# Get staged files safely
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [[ -z "$STAGED_FILES" ]]; then
    log_warning "No staged files"
    exit 0
fi

JS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|mjs)$' 2>/dev/null || true)
SKILL_DIRS=$(echo "$STAGED_FILES" | grep -E '^\.codex/skills/|/skills/' | cut -d'/' -f1-3 | sort -u 2>/dev/null || true)

log_debug "Found $(echo "$STAGED_FILES" | wc -l | tr -d ' ') staged files"
log_debug "JS files: $(echo "$JS_FILES" | wc -l | tr -d ' ')"

# Counters
declare -i CHECKS_PASSED=0
declare -i CHECKS_FAILED=0
declare -i TOTAL_CHECKS=0

# Function to run a check with timing (no eval!)
run_check() {
    local name="$1"
    local cmd="$2"
    local files="$3"
    
    TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
    
    if [[ -z "$files" ]]; then
        log_debug "Skipping $name: No relevant staged files"
        return 0
    fi
    
    log_info "▶️  $name"
    local start_time=$(date +%s)
    
    # Execute command directly - no eval!
    if bash -c "$cmd" 2>&1; then
        local end_time=$(date +%s)
        local duration=$((end_time - start_time))
        log_success "✓ $name passed (${duration}s)"
        log_metric "$HOOK_NAME" "$name" "pass" "$duration"
        CHECKS_PASSED=$((CHECKS_PASSED + 1))
        return 0
    else
        local end_time=$(date +%s)
        local duration=$((end_time - start_time))
        log_error "✗ $name failed (${duration}s)"
        log_metric "$HOOK_NAME" "$name" "fail" "$duration"
        CHECKS_FAILED=$((CHECKS_FAILED + 1))
        return 1
    fi
}

# ============================================
# CHECK 1: Lint staged JavaScript files
# ============================================
if [[ -n "$JS_FILES" ]]; then
    run_check "ESLint" "echo '$JS_FILES' | xargs -r npx eslint" "$JS_FILES" || true
fi

# ============================================
# CHECK 2: Validate config files
# ============================================
if echo "$STAGED_FILES" | grep -qE '\.(env|config\.(js|json))$'; then
    run_check "Config Validation" "npm run validate:config" "$STAGED_FILES" || true
fi

# ============================================
# CHECK 3: Run unit tests for changed test files
# ============================================
TEST_FILES=$(echo "$STAGED_FILES" | grep -E '\.(test|spec)\.(js|mjs)$' || true)
if [[ -n "$TEST_FILES" ]]; then
    test_pattern=""
    test_pattern=$(echo "$TEST_FILES" | tr '\n' '|' | sed 's/|$//')
    run_check "Unit Tests (changed)" "npm run test:unit -- --testPathPattern='$test_pattern'" "$TEST_FILES" || true
fi

# ============================================
# CHECK 4: Skill audit (if skills changed)
# ============================================
if [[ -n "$SKILL_DIRS" ]]; then
    for skill_dir in $SKILL_DIRS; do
        if [[ -f "$skill_dir/SKILL.md" ]]; then
            skill_name=""
            skill_name=$(basename "$skill_dir")
            run_check "Skill Audit: $skill_name" \
                "python3 '$HOME/.codex/skills/ultimate-skill-creator/scripts/audit_skill.py' '$skill_dir' --mode standard" \
                "$skill_dir" || true
        fi
    done
fi

# ============================================
# CHECK 5: Check for secrets/credentials (with timeout)
# ============================================
if command -v trufflehog &> /dev/null; then
    log_info "▶️  Secrets Scan"
    start_time=$(date +%s)
    
    if with_timeout 15 trufflehog git file://. --since-commit HEAD --only-verified --fail 2>&1; then
        end_time=$(date +%s)
        log_success "✓ Secrets scan passed ($((end_time - start_time))s)"
        CHECKS_PASSED=$((CHECKS_PASSED + 1))
    else
        end_time=$(date +%s)
        log_error "✗ Secrets scan failed ($((end_time - start_time))s)"
        CHECKS_FAILED=$((CHECKS_FAILED + 1))
    fi
    TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
else
    log_debug "TruffleHog not installed, skipping secrets scan"
fi

# ============================================
# CHECK 6: Validate commit message format (preview)
# ============================================
log_info "▶️  Commit Message Preview"

if [[ -f ".git/COMMIT_EDITMSG" ]]; then
    COMMIT_MSG=$(head -n1 .git/COMMIT_EDITMSG)
    
    if echo "$COMMIT_MSG" | grep -qE '^(feat|fix|docs|style|refactor|test|chore|security|db)(\(.+\))?: .+'; then
        log_success "✓ Commit message follows conventional format"
        CHECKS_PASSED=$((CHECKS_PASSED + 1))
    else
        log_warning "⚠️  Commit message doesn't follow conventional format"
        echo "   Expected: type(scope): subject"
        echo "   Example: feat(blockchain): add Solana escrow"
    fi
    TOTAL_CHECKS=$((TOTAL_CHECKS + 1))
fi

# ============================================
# Summary
# ============================================
echo ""
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log_info "Quality Gates Summary"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "Total checks: $TOTAL_CHECKS"
echo -e "${GREEN}Passed: $CHECKS_PASSED${NC}"
echo -e "${RED}Failed: $CHECKS_FAILED${NC}"
echo ""

if [[ $CHECKS_FAILED -gt 0 ]]; then
    log_error "❌ Commit blocked: $CHECKS_FAILED check(s) failed"
    echo ""
    echo "To bypass these checks (not recommended):"
    echo "  SKIP_PRE_COMMIT=1 git commit -m \"your message\""
    echo ""
    echo "To fix issues:"
    echo "  - Fix linting: npm run lint -- --fix"
    echo "  - Run tests: npm run test:unit"
    echo "  - Audit skill: python scripts/audit_skill.py <skill> --mode standard"
    exit 1
else
    log_success "✅ All quality gates passed!"
    log_success "✓ Commit allowed"
    exit 0
fi
