# Copy this file to .env and fill in your actual secrets. NEVER commit .env to git!

# Server Configuration
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/agrobridge

# JWT Secrets (Generate strong secrets with: openssl rand -base64 64)
JWT_ACCESS_SECRET=your-access-secret-min-64-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars-different-from-access

# CSRF Secret (Generate with: openssl rand -base64 32)
CSRF_SECRET=your-csrf-secret-min-32-chars-long-here

# CORS (comma-separated allowed origins)
CORS_ORIGINS=http://localhost:3000,https://agrobridge.global

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
