# Copy this file to .env and fill in your actual secrets. NEVER commit .env to git!

# Server Configuration
NODE_ENV=development
PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/agrobridge

# JWT Secrets (Generate strong secrets with: openssl rand -base64 64)
# WARNING: Minimum 64 characters required for HMAC-SHA256 security. Access and Refresh must be different.
JWT_ACCESS_SECRET=your-jwt-access-secret-must-be-at-least-64-characters-long-for-hmac-sha256-security
JWT_REFRESH_SECRET=your-jwt-refresh-secret-must-be-at-least-64-characters-long-and-different-from-access

# CSRF Secret (Generate with: openssl rand -base64 32)
CSRF_SECRET=your-csrf-secret-min-32-chars-long-here

# CORS (comma-separated allowed origins)
CORS_ORIGIN=http://localhost:3000,https://agrobridge.global

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# reCAPTCHA (frontend - injected into config-production.js via deployment pipeline)
# Get your site key from https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY=your-recaptcha-site-key-here

# Sentry APM (optional - leave empty to disable)
# Set window.AGROBRIDGE_SENTRY_DSN in index.html or via deployment pipeline
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
