# =============================================
# AGROBRIDGE ZTD - .HTACCESS OPTIMIZADO
# Versión: 2.0 | Enterprise Security & Performance
# =============================================

# === CONFIGURACIÓN BÁSICA DEL SERVIDOR ===
ServerSignature Off
Options -Indexes
Options +FollowSymLinks -MultiViews

# === ENCODING Y TIPOS MIME ===
AddDefaultCharset UTF-8
DefaultLanguage es-MX

<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType application/json .json
    AddType image/svg+xml .svg
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType font/ttf .ttf
    AddType image/webp .webp
    AddType image/avif .avif
</IfModule>

# === COMPRESIÓN AVANZADA GZIP/BROTLI ===
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif)$ no-gzip dont-vary
    SetEnvIfNoCase Request_URI \.(?:exe|t?gz|zip|bz2|sit|rar|pdf|avi|mov|mp4)$ no-gzip dont-vary
    SetEnvIfNoCase Request_URI \.(?:woff2?|ttf|eot|svg)$ no-gzip dont-vary
    
    # Comprimir todo lo demás
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/font-woff2
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject
    
    # Navegadores antiguos
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSI[E] !no-gzip !gzip-only-text/html
</IfModule>

# === CACHE Y EXPIRACIÓN - PERFORMANCE CRÍTICO ===
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Por defecto: 1 hora
    ExpiresDefault "access plus 1 hour"
    
    # HTML: 15 minutos (contenido dinámico)
    ExpiresByType text/html "access plus 15 minutes"
    
    # CSS y JS: 1 año (versionado)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
    
    # Imágenes: 1 mes
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/avif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 month"
    
    # Fuentes: 1 año
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    
    # JSON y datos: 1 día
    ExpiresByType application/json "access plus 1 day"
    ExpiresByType application/ld+json "access plus 1 day"
</IfModule>

# === HEADERS DE SEGURIDAD AVANZADOS (Issue #13 Fix) ===
<IfModule mod_headers.c>
    # HSTS - Solo en HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" env=HTTPS

    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"

    # Content Type Options
    Header always set X-Content-Type-Options "nosniff"

    # Frame Options
    Header always set X-Frame-Options "SAMEORIGIN"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # Permissions Policy (más restrictivo)
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"

    # CSP - Content Security Policy MEJORADO (Issue #13)
    # Nota: 'unsafe-inline' es necesario para estilos inline existentes
    # TODO: Migrar a nonces cuando se refactorice el CSS
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://api.agrobridge.global https://www.google-analytics.com https://wa.me; frame-ancestors 'self'; base-uri 'self'; form-action 'self' https://api.agrobridge.global; upgrade-insecure-requests"

    # Cross-Origin Policies
    Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"
    Header always set Cross-Origin-Embedder-Policy "unsafe-none"
    Header always set Cross-Origin-Resource-Policy "cross-origin"

    # Cache Control para recursos estáticos
    <FilesMatch "\.(css|js|woff2?|ttf|eot|svg|png|jpe?g|gif|webp|avif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # Cache Control para HTML
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "public, max-age=900, must-revalidate"
    </FilesMatch>

    # Remove Server headers
    Header unset Server
    Header unset X-Powered-By
</IfModule>

# === CORS CONFIGURATION (Issue #17 Fix) ===
<IfModule mod_headers.c>
    # Allow API requests from the frontend
    SetEnvIf Origin "^https://(www\.)?agrobridge\.global$" CORS_ORIGIN=$0
    SetEnvIf Origin "^https?://localhost(:[0-9]+)?$" CORS_ORIGIN=$0

    Header always set Access-Control-Allow-Origin %{CORS_ORIGIN}e env=CORS_ORIGIN
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-API-Version, Accept-Language" env=CORS_ORIGIN
    Header always set Access-Control-Max-Age "86400" env=CORS_ORIGIN
    Header always set Access-Control-Allow-Credentials "true" env=CORS_ORIGIN

    # Handle preflight OPTIONS requests
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>

# === REDIRECCIONES Y REWRITES ===
RewriteEngine On

# 1. REDIRECCIÓN HTTPS FORZADA (MEJORADA)
RewriteCond %{HTTPS} off [OR]
RewriteCond %{SERVER_PORT} 80
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

# 2. REDIRECCIÓN WWW A NON-WWW (O VICEVERSA - ELIGE UNA)
# Para redirigir www a non-www:
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# Para redirigir non-www a www (descomenta si prefieres):
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. ELIMINAR SLASH FINAL (SEO)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} ^(.+)/$
RewriteRule ^(.+)/$ /$1 [L,R=301]

# 4. PREVENIR HOTLINKING DE IMÁGENES
RewriteCond %{HTTP_REFERER} !^$
RewriteCond %{HTTP_REFERER} !^https?://(?:www\.)?agrobridge\.global [NC]
RewriteCond %{HTTP_REFERER} !^https?://(?:www\.)?localhost [NC]
RewriteRule \.(jpe?g|png|gif|webp|avif)$ - [NC,F,L]

# 5. PROTECCIÓN DE ARCHIVOS SENSIBLES
<FilesMatch "^(\.htaccess|\.htpasswd|\.env|composer\.json|composer\.lock|package\.json|yarn\.lock|webpack\.config\.js|\.gitignore|README\.md)$">
    Order deny,allow
    Deny from all
</FilesMatch>

<FilesMatch "\.(log|sql|bak|tmp)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# 6. BLOQUEO DE USER AGENTS MALICIOSOS
RewriteCond %{HTTP_USER_AGENT} (libwww-perl|wget|python|nikto|curl|scan|java|winhttp|clshttp|loader) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (<|>|'|%0A|%0D|%27|%3C|%3E|%00) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (;|<|>|'|"|\)|\(|%0A|%0D|%22|%27|%28|%3C|%3E|%00).*(libwww-perl|wget|python|nikto|curl|scan|java|winhttp|HTTrack|clshttp|archiver|loader|email|harvest|extract|grab|miner) [NC]
RewriteRule .* - [F,L]

# 7. PREVENIR ACCESO A DIRECTORIOS
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# === MANEJO DE ERRORES PERSONALIZADO ===
ErrorDocument 400 /error/400.html
ErrorDocument 401 /error/401.html
ErrorDocument 403 /error/403.html
ErrorDocument 404 /error/404.html
ErrorDocument 500 /error/500.html
ErrorDocument 503 /error/503.html

# === COMPRESIÓN AVANZADA PARA WEBP/AVIF ===
<IfModule mod_rewrite.c>
    # Servir WebP si está disponible y el navegador lo soporta
    RewriteCond %{HTTP_ACCEPT} image/webp
    RewriteCond %{DOCUMENT_ROOT}/$1.webp -f
    RewriteRule ^(.*)\.(jpe?g|png)$ $1.webp [T=image/webp,L]
    
    # Servir AVIF si está disponible y el navegador lo soporta
    RewriteCond %{HTTP_ACCEPT} image/avif
    RewriteCond %{DOCUMENT_ROOT}/$1.avif -f
    RewriteRule ^(.*)\.(jpe?g|png|webp)$ $1.avif [T=image/avif,L]
</IfModule>

# === HEADER PARA WEBP/AVIF ===
<IfModule mod_headers.c>
    <FilesMatch "\.(webp|avif)$">
        Header append Vary Accept
    </FilesMatch>
</IfModule>

# === OPTIMIZACIONES PARA SITEGROUND ===
<IfModule mod_env.c>
    # Habilitar buffer de output para SiteGround
    SetEnv output_buffering On
</IfModule>

# === PROTECCIÓN CONTRA ATAQUES COMUNES ===
# Protección contra injection en URLs
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteRule .* - [F,L]

# Protección contra base64 encode
RewriteCond %{QUERY_STRING} base64_encode.*\(.*\) [OR]
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]

# === CONFIGURACIÓN PARA SINGLE PAGE APPLICATION (SPA) ===
# Si estás usando Vue/React/Angular, descomenta:
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteRule . /index.html [L]

# === PERFORMANCE - KEEP ALIVE ===
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# === COMPRESIÓN ADICIONAL PARA SITEGROUND ===
<IfModule mod_suphp.c>
    suPHP_ConfigPath /opt/php-7.4/lib
</IfModule>

# === FIN DEL ARCHIVO ===
# Agrobridge ZTD - Secure & Optimized