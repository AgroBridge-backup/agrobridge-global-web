{
  "name": "agrobridge-global-2.0",
  "version": "2.0.0",
  "description": "AgroBridge Global - Primer sistema ZTD en México 100% desarrollado por Mexicanos. Tecnología blockchain para trazabilidad agrícola premium.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:prod": "NODE_ENV=production node src/index.js",
    "dev": "nodemon index.js",
    "deploy": "node tools/deploy/deploy-masterpiece.js",
    "deploy:full": "npm run pre-deploy && npm run deploy && npm run post-deploy",
    "pre-deploy": "node tools/deploy/pre-deploy.js",
    "post-deploy": "node tools/deploy/post-deploy.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration --coverage",
    "test:a11y": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/accessibility --coverage",
    "test:e2e": "npx playwright test",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --coverage --reporters=default --reporters=jest-junit",
    "test:backend": "npm run test:blockchain && npm run test:security && npm run test:api",
    "test:blockchain": "node tools/tests/blockchain-test.js",
    "test:security": "node tools/tests/security-test.js",
    "test:api": "node tools/tests/api-test.js",
    "test:compatibility": "node tools/tests/compatibility-test.js",
    "test:hash": "node tools/tests/test-hash-integrity.js",
    "persistence:check": "node tools/persistence-check.js",
    "persistence:stats": "node tools/persistence-check.js --stats",
    "persistence:backup": "node tools/cli/backup-manager.js --create",
    "blockchain:init": "node tools/cli/blockchain-init.js",
    "blockchain:audit": "node tools/cli/blockchain-audit.js",
    "blockchain:stats": "node tools/cli/blockchain-stats.js",
    "monitor": "node tools/monitor/hash-monitor.js",
    "monitor:health": "node tools/monitor/health-monitor.js",
    "lotes:register": "node tools/cli/register-lotes.js",
    "lotes:seal": "node tools/cli/seal-lotes.js",
    "optimize": "node tools/optimizer/agrobridge-asset-optimizer.js",
    "security:scan": "node tools/security/security-scanner.js",
    "clean": "rm -rf node_modules && npm cache clean --force",
    "reset:dev": "node tools/cli/reset-development.js",
    "docs": "node tools/docs/generate-docs.js",
    "logs:view": "node tools/cli/log-viewer.js",
    "prebuild": "mkdir -p public_html/dist/scripts public_html/dist/assets public_html/dist/styles",
    "build:js": "for f in public_html/scripts/*.js; do npx esbuild \"$f\" --minify --outdir=public_html/dist/scripts/; done && npx esbuild public_html/config-production.js --minify --outdir=public_html/dist/",
    "build:css": "for f in public_html/assets/*.css; do npx esbuild \"$f\" --minify --outdir=public_html/dist/assets/; done && for f in public_html/styles/*.css; do npx esbuild \"$f\" --minify --outdir=public_html/dist/styles/; done",
    "build": "npm run build:js && npm run build:css"
  },
  "keywords": [
    "blockchain",
    "agriculture",
    "mexico",
    "ztd",
    "zero-trust",
    "supply-chain",
    "traceability",
    "agtech",
    "berries",
    "avocado",
    "michoacan",
    "export",
    "premium",
    "food-safety",
    "cryptography",
    "sha256",
    "immutable-ledger",
    "quality-control",
    "export-certification"
  ],
  "author": {
    "name": "AgroBridge Global Team",
    "email": "tecnologia@agrobridge.global",
    "url": "https://agrobridge.global"
  },
  "contributors": [
    {
      "name": "Equipo de Ingeniería AgroBridge",
      "email": "ingenieria@agrobridge.global"
    },
    {
      "name": "Equipo Blockchain ZTD",
      "email": "blockchain@agrobridge.global"
    }
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "rate-limit-redis": "^4.3.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agrobridge/global-2.0.git"
  },
  "bugs": {
    "url": "https://github.com/agrobridge/global-2.0/issues",
    "email": "soporte@agrobridge.global"
  },
  "homepage": "https://agrobridge.global",
  "config": {
    "port": "3000",
    "api_version": "v2",
    "blockchain_difficulty": "1",
    "hash_algorithm": "SHA256"
  }
}
