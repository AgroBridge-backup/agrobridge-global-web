{
  "name": "agrobridge-global-2.0",
  "version": "2.0.0",
  "description": "AgroBridge Global - Primer sistema ZTD en México 100% desarrollado por Mexicanos. Tecnología blockchain para trazabilidad agrícola premium.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "prepare": "if [ -f scripts/setup-git-hooks.sh ]; then ./scripts/setup-git-hooks.sh; fi",
    "postinstall": "npm run prepare",
    "start": "node src/index.js",
    "start:prod": "NODE_ENV=production node src/index.js",
    "dev": "nodemon src/index.js",
    "lint": "eslint src/ public_html/scripts/ tests/ --ext .js",
    "lint:fix": "eslint src/ public_html/scripts/ tests/ --ext .js --fix",
    "lint:brand": "node scripts/sync-brand-logo.mjs --check",
    "sync:brand": "node scripts/sync-brand-logo.mjs",
    "validate:config": "node scripts/validate-config.mjs",
    "hooks:install": "./scripts/setup-git-hooks.sh",
    "hooks:uninstall": "rm -f .git/hooks/pre-commit .git/hooks/commit-msg .git/hooks/pre-push .git/hooks/post-checkout .git/hooks/prepare-commit-msg",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.js tests/integration --coverage",
    "test:a11y": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.accessibility.config.js tests/accessibility --coverage",
    "test:security": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.security.config.js",
    "test:smoke": "node scripts/server-smoke.mjs",
    "test:release-gates": "npm run lint:brand && npm run validate:config && npm run test:security && npm run test:smoke",
    "test:e2e": "npx playwright test",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --coverage --reporters=default --reporters=jest-junit",
    "clean": "rm -rf node_modules && npm cache clean --force"
  },
  "keywords": [
    "blockchain",
    "agriculture",
    "mexico",
    "ztd",
    "zero-trust",
    "supply-chain",
    "traceability",
    "agtech",
    "berries",
    "avocado",
    "michoacan",
    "export",
    "premium",
    "food-safety",
    "cryptography",
    "sha256",
    "immutable-ledger",
    "quality-control",
    "export-certification"
  ],
  "author": {
    "name": "Alejandro Navarro Ayala - CEO & Founder, AgroBridge",
    "email": "ceo@agrobridge.global",
    "url": "https://agrobridge.global"
  },
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "rate-limit-redis": "^4.3.1",
    "validator": "^13.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "browserslist": {
    "production": [
      ">0.3%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agrobridge/global-2.0.git"
  },
  "bugs": {
    "url": "https://github.com/agrobridge/global-2.0/issues",
    "email": "soporte@agrobridge.global"
  },
  "homepage": "https://agrobridge.global"
}
